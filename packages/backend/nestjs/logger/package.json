{
  "name": "@adatechnology/nestjs-logger",
  "version": "0.0.1",
  "description": "NestJS dynamic module for structured JSON logging with ALS context, TraceStack, and distributed tracing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "build:watch": "tsup src/index.ts --format cjs --dts --watch",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": ["nestjs", "logger", "logging", "tracing", "als"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
