{
  "name": "@adatechnology/drizzle-provider",
  "version": "0.1.0",
  "description": "Typed Drizzle ORM provider for Bun SQL and PostgreSQL",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "bun test",
    "test:integration": "bun test --preload ./src/require-test-database.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "bun",
    "drizzle",
    "postgresql",
    "sql"
  ],
  "author": "Ada Technology",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "drizzle-orm": "1.0.0-rc.4"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
