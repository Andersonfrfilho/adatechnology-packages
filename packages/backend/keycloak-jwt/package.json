{
  "name": "@adatechnology/keycloak-jwt",
  "version": "0.0.0",
  "description": "Strict Keycloak access-token verification for Bun applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "bun test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "bun",
    "jose",
    "jwt",
    "keycloak",
    "oidc"
  ],
  "author": "Ada Technology",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
