# Node & Typescript
node_modules
dist
dist-server
lib-cov
coverage
.nyc_output
*.tsbuildinfo
*.log

# Stray build artifacts inside source directories (tsc/IDE leaks)
packages/**/src/**/*.js
packages/**/src/**/*.js.map
packages/**/src/**/*.d.ts
!packages/**/src/**/*.spec.ts
!packages/**/src/**/*.test.ts

# Turbo
.turbo

