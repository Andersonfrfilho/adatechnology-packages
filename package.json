{
  "name": "fullstack-monorepo",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "version": "0.0.0",
  "description": "Full-stack monorepo: NestJS backend libraries + frontend/mobile client libraries",
  "workspaces": [
    "packages/nestjs/*",
    "packages/frontend/*"
  ],
  "scripts": {
    "prepare": "husky install",
    "bootstrap": "pnpm install",
    "build": "pnpm run build:all",
    "build:all": "pnpm run build:nestjs && pnpm run build:frontend",
    "build:nestjs": "pnpm --filter='@adatechnology/logger' run build && pnpm --filter='@adatechnology/cache' run build && pnpm --filter='@adatechnology/http-client' run build && pnpm --filter='@adatechnology/shared' run build && pnpm --filter='@adatechnology/auth-keycloak' run build && pnpm --filter='@adatechnology/keycloak-admin' run build",
    "build:frontend": "pnpm --filter='@adatechnology/logger-client' run build",
    "build:example": "pnpm --filter=example run build",
    "clean": "rm -rf packages/**/dist",
    "dev": "turbo run dev --parallel",
    "changeset": "changeset",
    "version:changeset": "changeset version",
    "publish:changesets": "changeset publish",
    "watch:packages": "pnpm -r --parallel run build:watch"
  },
  "lint-staged": {
    "packages/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.16 || ^9",
    "@nestjs/core": "^11 || ^9.0.5"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.26.0",
    "@types/node": "^22.10.7",
    "changesets": "^1.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "pnpm": "^10.28.2",
    "tslib": "^2.5.0",
    "turbo": "^2.9.14",
    "typescript": "^5.2.0",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "rxjs": "^7.8.2"
  },
  "pnpm": {
    "overrides": {
      "handlebars": ">=4.7.9",
      "serialize-javascript": ">=7.0.3",
      "flatted": ">=3.4.2",
      "esbuild": ">=0.25.0",
      "fast-uri": ">=3.1.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0": ">=4.0.4",
      "path-to-regexp@>=8.0.0": ">=8.4.0",
      "vite": ">=6.4.2",
      "follow-redirects": ">=1.16.0",
      "lodash": ">=4.18.1",
      "axios": ">=1.15.2",
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@2": "^2.0.3",
      "brace-expansion@>=4": "^5.0.6",
      "postcss": ">=8.5.15",
      "file-type": ">=21.3.2",
      "@nestjs/core": ">=11.1.18",
      "@nestjs/common": ">=11.1.18",
      "@nestjs/platform-express": ">=11.1.18",
      "ajv": ">=8.18.0",
      "qs": ">=6.15.2"
    }
  }
}
