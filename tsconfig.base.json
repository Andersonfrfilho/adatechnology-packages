{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@adatechnology/nestjs-logger": ["packages/backend/nestjs-logger/src"],
      "@adatechnology/nestjs-logger/*": ["packages/backend/nestjs-logger/src/*"],
      "@adatechnology/nestjs-cache": ["packages/backend/nestjs-cache/src"],
      "@adatechnology/nestjs-cache/*": ["packages/backend/nestjs-cache/src/*"],
      "@adatechnology/nestjs-http-client": ["packages/backend/nestjs-http-client/src"],
      "@adatechnology/nestjs-http-client/*": ["packages/backend/nestjs-http-client/src/*"],
      "@adatechnology/shared": ["packages/backend/shared/src"],
      "@adatechnology/shared/*": ["packages/backend/shared/src/*"],
      "@adatechnology/nestjs-auth-keycloak": ["packages/backend/nestjs-auth-keycloak/src"],
      "@adatechnology/nestjs-auth-keycloak/*": ["packages/backend/nestjs-auth-keycloak/src/*"],
      "@adatechnology/nestjs-keycloak-admin": ["packages/backend/nestjs-keycloak-admin/src"],
      "@adatechnology/nestjs-keycloak-admin/*": ["packages/backend/nestjs-keycloak-admin/src/*"],
      "@adatechnology/nestjs-package": ["packages/backend/nestjs-package/src"],
      "@adatechnology/nestjs-package/*": ["packages/backend/nestjs-package/src/*"],
      "#shared": ["packages/backend/shared/src"],
      "#shared/*": ["packages/backend/shared/src/*"],
      "@adatechnology/logger-client": ["packages/frontend/logger-client/src"],
      "@adatechnology/logger-client/*": ["packages/frontend/logger-client/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
